<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>EnvironmentVariables</key>
	<dict>
		<key>PATH</key>
		<string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
		<key>WINDOW_MINUTES</key>
		<string>5</string>
		<key>L1_THRESHOLD</key>
		<string>3</string>
		<key>L2_THRESHOLD</key>
		<string>5</string>
		<key>L3_THRESHOLD</key>
		<string>10</string>
		<key>PROBE_ENABLED</key>
		<string>1</string>
		<key>ALERT_COOLDOWN_SEC</key>
		<string>600</string>
	</dict>
	<key>Label</key>
	<string>local.sub2api-openai-egress-monitor</string>
	<key>ProgramArguments</key>
	<array>
		<string>/bin/zsh</string>
		<string>/Users/yunque/services/sub2api-upstream-custom/tools/monitor_openai_egress_errors.sh</string>
	</array>
	<key>RunAtLoad</key>
	<true/>
	<key>StartInterval</key>
	<integer>180</integer>
	<key>StandardErrorPath</key>
	<string>/Users/yunque/Library/Logs/sub2api-openai-egress-monitor.err.log</string>
	<key>StandardOutPath</key>
	<string>/Users/yunque/Library/Logs/sub2api-openai-egress-monitor.out.log</string>
	<key>WorkingDirectory</key>
	<string>/Users/yunque/services/sub2api-upstream-custom</string>

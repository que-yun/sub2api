# =============================================================================
# Sub2API Gzip Front Proxy Environment Example
# =============================================================================
# Copy to deploy/gzip-front-proxy.env when you want a separate ingress for
# remote/Tailscale/cloudflared traffic.
#
# Recommended current topology:
#   local clients      -> 127.0.0.1:6780 -> sub2api
#   remote ingress     -> 127.0.0.1:6791 -> gzip front proxy -> 127.0.0.1:6780
# =============================================================================

GZIP_FRONT_PROXY_LISTEN=127.0.0.1:6791
GZIP_FRONT_PROXY_UPSTREAM=http://127.0.0.1:6780
GZIP_FRONT_PROXY_MIN_BYTES=65536
GZIP_FRONT_PROXY_MAX_BUFFER_BYTES=8388608
GZIP_FRONT_PROXY_PATHS=/v1/responses,/responses,/v1/chat/completions,/chat/completions
GZIP_FRONT_PROXY_DISABLE_KEEPALIVES=false
GZIP_FRONT_PROXY_SSE_HEARTBEAT_INTERVAL=10s
GZIP_FRONT_PROXY_READ_TIMEOUT=30s
GZIP_FRONT_PROXY_WRITE_TIMEOUT=0s
GZIP_FRONT_PROXY_IDLE_TIMEOUT=75s
